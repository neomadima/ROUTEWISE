<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map Background -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.DashboardFragment" />

    <!-- Top Navigation Instruction Bar - Green (Shown during trip) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topInstructionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        android:visibility="gone"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        android:backgroundTint="#0F9D58">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Center Content: Direction Sign (Large & Black) -->
            <LinearLayout
                android:id="@+id/directionContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivManeuverIcon"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="#000000" />

                <TextView
                    android:id="@+id/tvManeuverDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100 m"
                    android:textColor="#000000"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNextRoadName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Irwin St"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:alpha="0.9" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_white_alpha"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#0F9D58" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Top Bar (Drawer Toggle) - Hidden during trip -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/drawerCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        android:layout_gravity="top|start"
        app:strokeWidth="0dp">

        <ImageButton
            android:id="@+id/btnOpenDrawer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="?attr/colorPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Top Search Bar - Hidden during trip -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="80dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/autocomplete_fragment"
            android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Side Buttons (Search, Sound, Report) - Shown during trip -->
    <LinearLayout
        android:id="@+id/sideActionsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideRecenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideSound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />
    </LinearLayout>

    <!-- Speed Circle - Repositioned to Bottom Left like the picture -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/speedCircleContainer"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="110dp"
        android:visibility="gone"
        app:cardCornerRadius="32dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#DDDDDD"
        android:backgroundTint="#FFFFFF">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ProgressBar
                android:id="@+id/speedProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@drawable/bg_speed_circle"
                android:max="160"
                android:progress="0"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvMapSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#333333"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#666666"
                    android:textSize="10sp" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRecenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:fabSize="mini"
        android:layout_gravity="bottom|start"
        app:backgroundTint="?attr/colorSurface"
        app:tint="?attr/colorPrimary" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Report Incident"
        android:src="@android:drawable/ic_input_add"
        android:layout_gravity="bottom|end"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />

    <!-- Bottom Trip Status Bar - White (Shown during trip) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tripStatusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        android:layout_margin="0dp"
        android:backgroundTint="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Cancel Button (X) -->
            <ImageButton
                android:id="@+id/btnCancelTrip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#666666" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMapDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 hr 4 min"
                    android:textColor="#0F9D58"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvMapDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="121"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvMapDistanceUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" km"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textColor="#666666" />
                    <TextView
                        android:id="@+id/tvMapEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8:19 pm"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/distanceProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMapDirections"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_directions"
                app:tint="#666666" />

            <ImageButton
                android:id="@+id/btnExpandStatus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/arrow_up_float"
                app:tint="#666666" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Place Detail Bottom Sheet -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/placeDetailSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true"
        app:strokeWidth="0dp"
        android:backgroundTint="#2D3135">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="?attr/colorOutlineVariant" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvPlaceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnCloseSheet"
                        android:text="Place Name"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <ImageButton
                        android:id="@+id/btnCloseSheet"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#FFFFFF" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPlaceAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Address line goes here"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="#BEC1C5"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvTravelTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="· -- min"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="#BEC1C5" />
                </LinearLayout>

            <LinearLayout
                android:id="@+id/quickActionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSheetDirections"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Directions"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_menu_directions"
                    app:cornerRadius="28dp"
                    android:backgroundTint="#D1E4FF"
                    android:textColor="#001D36"
                    app:iconTint="#001D36" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSheetStart"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Start"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_media_play"
                    app:cornerRadius="28dp"
                    android:backgroundTint="#4F4600"
                    android:textColor="#FFFFFF"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>