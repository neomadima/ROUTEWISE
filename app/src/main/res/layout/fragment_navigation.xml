<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map Background -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Navigation Instruction Bar - Green -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topInstructionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        android:backgroundTint="#0F9D58">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/directionContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivManeuverIcon"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="#000000" />

                <TextView
                    android:id="@+id/tvManeuverDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100 m"
                    android:textColor="#000000"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNextRoadName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next Road"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:alpha="0.9" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVoice"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_white_alpha"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#0F9D58" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAlerts"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Alerts"
                android:textColor="@android:color/white" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Speed Circle - Bottom Left -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/speedCircleContainer"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="110dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#DDDDDD"
        android:backgroundTint="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#333333"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="km/h"
                android:textColor="#666666"
                android:textSize="10sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Speed Limit Badge -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/speedLimitContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="88dp"
        android:layout_marginBottom="110dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:strokeWidth="2dp"
        app:strokeColor="#FF0000"
        android:backgroundTint="#FFFFFF">
        <TextView
            android:id="@+id/tvSpeedLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="60"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Side Actions -->
    <LinearLayout
        android:id="@+id/sideActionsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSideEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            app:fabSize="mini"
            app:backgroundTint="#FFFFFF"
            app:tint="#666666" />
    </LinearLayout>

    <!-- Bottom Trip Status Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        android:layout_margin="0dp"
        android:backgroundTint="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btnStopNav"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#666666" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRemainingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 hr 4 min"
                    android:textColor="#0F9D58"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvMapDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="121"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvMapDistanceUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" km"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textColor="#666666" />
                    <TextView
                        android:id="@+id/tvEta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8:19 pm"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textColor="#666666" />
                    <TextView
                        android:id="@+id/tvTransportMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Car"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/routeProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:progress="0"
                    app:trackCornerRadius="4dp" />
            </LinearLayout>

            <View
                android:id="@+id/vMovingIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_margin="16dp"
                android:background="@android:color/holo_green_light"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Alerts Feed Overlay -->
    <FrameLayout
        android:id="@+id/alertsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:visibility="gone"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseAlerts"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back to Map"
                app:icon="@android:drawable/ic_menu_revert" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNavIncidents"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="16dp"
                tools:listitem="@layout/item_incident" />
        </LinearLayout>
    </FrameLayout>

    <!-- Hazard Warning Popup -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/warningCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="150dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        android:backgroundTint="#CC0000">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">
            <TextView
                android:id="@+id/tvWarningTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HAZARD AHEAD"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvWarningDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accident reported"
                android:textColor="#FFFFFF" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseWarning"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dismiss"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Invisible Hooks for code compatibility if needed -->
    <TextView android:id="@+id/tvDistance" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/tvNextStreet" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
