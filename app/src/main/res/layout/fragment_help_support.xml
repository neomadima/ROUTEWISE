<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Help &amp; Support"
            app:navigationIcon="@android:drawable/ic_menu_revert" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. FAQ Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frequently Asked Questions"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginBottom="12dp"
                android:textColor="?attr/colorPrimary" />

            <!-- General FAQ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Q: How do I search for a destination?\nA: Use the search bar at the top of the Dashboard. Start typing and select a result.\n\nQ: How do I see my current location?\nA: Tap the target icon on the map to recenter on your position.\n\nQ: The route card disappeared – how do I bring it back?\nA: Tap the destination marker on the map again, or use the 'Show route' button in the search bar."
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Route & Navigation FAQ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Route &amp; Navigation"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Q: Directions vs Start?\nA: 'Directions' shows the route on the map for preview. 'Start' launches full active navigation with voice guidance.\n\nQ: Can I change my destination while navigating?\nA: Yes, tap the search icon or cancel the current trip to set a new destination.\n\nQ: How accurate is the estimated travel time?\nA: We use live traffic data and historical patterns to provide the most accurate ETA possible."
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Offline & Data FAQ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offline &amp; Data"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Q: Does the app work without an internet connection?\nA: Basic map viewing works, but routing and live traffic require a data connection.\n\nQ: How can I save maps for offline use?\nA: Go to App Settings and select 'Offline Maps' to download specific regions."
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy & Permissions FAQ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy &amp; Permissions"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Q: Why does the app need my location permission?\nA: To provide accurate navigation, real-time alerts, and to show your position on the map.\n\nQ: Is my location data shared with anyone?\nA: Your location data is used only for navigation purposes and is not sold to third parties."
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Contact Support -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Support"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmailSupport"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email: support@routewise.co.za"
                        android:textAlignment="viewStart"
                        app:icon="@android:drawable/ic_dialog_email" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCallSupport"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Call Us: +27 11 123 4567"
                        android:textAlignment="viewStart"
                        app:icon="@android:drawable/ic_menu_call" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Report a Problem Form -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report a Problem"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Issue Type">
                        <AutoCompleteTextView
                            android:id="@+id/spinnerIssueType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Description">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProblemDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitProblem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Send Report" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Tutorials -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tutorials"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvTutorial1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="▶ How to set a destination and pick a route"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp" />
                    <TextView
                        android:id="@+id/tvTutorial2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="▶ How to hide the route card without canceling your trip"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp" />
                    <TextView
                        android:id="@+id/tvTutorial3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="▶ How to start voice navigation"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Legal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Legal Documents"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:textColor="?attr/colorPrimary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrivacyPolicy"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Privacy Policy"
                        android:textAlignment="viewStart" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTermsOfService"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Terms of Service"
                        android:textAlignment="viewStart" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenSource"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open Source Licenses"
                        android:textAlignment="viewStart" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>