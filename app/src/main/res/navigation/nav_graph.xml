<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.routewise.sa.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_adminPanelFragment"
            app:destination="@id/adminPanelFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.routewise.sa.ui.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_registerFragment_to_adminPanelFragment"
            app:destination="@id/adminPanelFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.routewise.sa.ui.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />
    <fragment
        android:id="@+id/liveAlertsFragment"
        android:name="com.routewise.sa.ui.LiveAlertsFragment"
        android:label="Live Alerts"
        tools:layout="@layout/fragment_live_alerts" />
    <fragment
        android:id="@+id/reportIncidentFragment"
        android:name="com.routewise.sa.ui.ReportIncidentFragment"
        android:label="Report Incident"
        tools:layout="@layout/fragment_report_incident" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.routewise.sa.ui.ProfileFragment"
        android:label="My Profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/locationSettingsFragment"
        android:name="com.routewise.sa.ui.LocationSettingsFragment"
        android:label="Location Settings"
        tools:layout="@layout/fragment_location_settings" />
    <fragment
        android:id="@+id/adminPanelFragment"
        android:name="com.routewise.sa.ui.AdminPanelFragment"
        android:label="Admin Panel"
        tools:layout="@layout/fragment_admin_panel" />

    <fragment
        android:id="@+id/nav_help"
        android:name="com.routewise.sa.ui.HelpSupportFragment"
        android:label="Help &amp; Support"
        tools:layout="@layout/fragment_help_support" />

    <fragment
        android:id="@+id/routePlanningFragment"
        android:name="com.routewise.sa.ui.RoutePlanningFragment"
        android:label="Plan Your Trip"
        tools:layout="@layout/fragment_route_planning">
        <action
            android:id="@+id/action_routePlanningFragment_to_navigationFragment"
            app:destination="@id/navigationFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigationFragment"
        android:name="com.routewise.sa.ui.NavigationFragment"
        android:label="Route Planning &amp; Navigation"
        tools:layout="@layout/fragment_navigation">
        <argument
            android:name="lat"
            app:argType="float" />
        <argument
            android:name="lng"
            app:argType="float" />
        <argument
            android:name="dest_name"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <action
        android:id="@+id/action_global_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />
</navigation>